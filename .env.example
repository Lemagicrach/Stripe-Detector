# Stripe
# â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_CLIENT_ID=ca_...
STRIPE_CONNECT_REDIRECT_URI=http://localhost:3000/api/stripe/connect
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional. When set, the Connect webhook route also accepts events signed by
# this secret (in addition to STRIPE_WEBHOOK_SECRET). Use it only to validate
# idempotency from Stripe Test mode against the production endpoint. Events
# signed with this secret are tagged `source = "connect_test"` in the
# stripe_events_processed dedup table.
STRIPE_WEBHOOK_SECRET_TEST=

# Price IDs (create products in Stripe Dashboard → Products)
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...
# Stripe Billing webhook (separate from Connect webhook)
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...
# Optional. Test-mode counterpart to STRIPE_BILLING_WEBHOOK_SECRET. Same
# semantics: events signed with this secret are tagged `source = "billing_test"`.
STRIPE_BILLING_WEBHOOK_SECRET_TEST=

